# Trello API (formulário de briefing e contato)
# Obtenha em: https://trello.com/power-ups/admin
TRELLO_API_KEY=
TRELLO_TOKEN=

# ID da lista onde os cards de briefing/leads serão criados
# Encontre na URL ao abrir a lista no Trello (ex: .../board/XXX/.../list/ESTE_É_O_ID)
TRELLO_LEADS_LIST_ID=

# ID da lista para o formulário de contato (se diferente)
TRELLO_CONTACT_LIST_ID=
